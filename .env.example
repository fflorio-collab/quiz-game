# Database - usa SQLite per sviluppo locale (più semplice) o PostgreSQL per produzione
# Per SQLite locale:
DATABASE_URL="file:./dev.db"

# Per PostgreSQL (es. Railway, Supabase, Neon):
# DATABASE_URL="postgresql://user:password@host:5432/quizgame"

# Porta del server Socket.io
SOCKET_PORT=3001

# URL pubblico del Socket.io server (per il client)
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"

# Chiave admin per accedere al pannello di gestione domande
ADMIN_PASSWORD="cambia-questa-password"

# JWT secret per sessioni (genera una stringa random lunga)
JWT_SECRET="cambia-con-una-stringa-random-di-almeno-32-caratteri"

# ========== NEXTAUTH / AUTH.JS ==========
# Secret per firmare i JWT di sessione — OBBLIGATORIO in produzione.
# Generane uno con: openssl rand -base64 32
AUTH_SECRET="cambia-con-una-stringa-random-di-almeno-32-caratteri"
# URL pubblico dell'app. In dev resta così, in prod es. https://superfabri.app
NEXTAUTH_URL="http://localhost:3000"

# ---------- Google OAuth ----------
# 1. Vai su https://console.cloud.google.com/apis/credentials
# 2. Crea "OAuth client ID" → Web application
# 3. Authorized redirect URI: http://localhost:3000/api/auth/callback/google  (in prod: https://tuodominio/api/auth/callback/google)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# ---------- Twitch OAuth ----------
# 1. Vai su https://dev.twitch.tv/console/apps e registra una nuova app
# 2. OAuth Redirect URL: http://localhost:3000/api/auth/callback/twitch  (in prod il dominio corrispondente)
# TWITCH_CLIENT_ID=""
# TWITCH_CLIENT_SECRET=""

# ---------- Facebook OAuth ----------
# 1. Vai su https://developers.facebook.com/apps/ e crea un'app "Consumer"
# 2. Prodotto "Facebook Login" → Valid OAuth Redirect URI: http://localhost:3000/api/auth/callback/facebook
# FACEBOOK_CLIENT_ID=""
# FACEBOOK_CLIENT_SECRET=""

# ---------- Apple Sign In ----------
# Richiede Apple Developer Account ($99/anno) e un flusso più complesso.
# 1. https://developer.apple.com/account/resources/identifiers/list/serviceId → crea un Service ID (es. com.superfabri.login)
# 2. Configura "Sign in with Apple" con Return URL: https://tuodominio/api/auth/callback/apple (Apple non accetta localhost)
# 3. Genera una private key (.p8) in "Keys" con capability "Sign in with Apple"
# 4. Usa APPLE_ID = Service ID, APPLE_SECRET = client_secret JWT generato dalla .p8
#    (vedi https://authjs.dev/getting-started/providers/apple per generarlo)
# APPLE_ID=""
# APPLE_SECRET=""

# ========== STRIPE (pagamenti) ==========
# Lascia vuoto per disabilitare il flow /api/checkout (il bottone mostra un messaggio).
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# Price ID creati sul dashboard Stripe (Prodotti → crea prezzo ricorrente)
# STRIPE_PRICE_ID_PRO_MONTH="price_..."
# STRIPE_PRICE_ID_EDU_MONTH="price_..."
