// Prisma schema PER PRODUZIONE (Railway / PostgreSQL).
// In locale usa prisma/schema.prisma (SQLite).
// Build di produzione: npm run build:prod (prisma generate --schema=... && next build)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========== AUTENTICAZIONE (NextAuth v5 / Auth.js) ==========

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  emailVerified DateTime?
  username      String?   @unique
  displayName   String?
  image         String?
  passwordHash  String?
  level         Int       @default(1)
  xp            Int       @default(0)
  coins         Int       @default(0)
  totalGames    Int       @default(0)
  totalWins     Int       @default(0)
  totalCorrect  Int       @default(0)
  bestStreak    Int       @default(0)
  dailyStreak   Int       @default(0)
  lastLoginDate DateTime?
  plan                String  @default("FREE")
  stripeCustomerId    String?
  subscriptionStatus  String?
  accounts      Account[]
  sessions      Session[]
  players       Player[]
  leaderboards  Leaderboard[]
  badges        UserBadge[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([username])
}

// ========== GAMIFICATION ==========

model Badge {
  id          String      @id @default(cuid())
  slug        String      @unique
  name        String
  description String
  icon        String
  rarity      String
  users       UserBadge[]
}

model UserBadge {
  id         String   @id @default(cuid())
  userId     String
  badgeId    String
  unlockedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge      Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Category {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  icon      String?
  color     String?
  parentId  String?
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  Category[] @relation("CategoryTree")
  sortOrder Int        @default(0)
  questions Question[]
  createdAt DateTime   @default(now())

  @@index([parentId])
}

model Question {
  id            String      @id @default(cuid())
  text          String
  type          String      @default("MULTIPLE_CHOICE")
  difficulty    String      @default("MEDIUM")
  timeLimit     Int         @default(20)
  points        Int         @default(1000)
  explanation   String?
  imageUrl      String?
  mediaType     String?
  openAnswer    String?
  wordTemplate  String?
  categoryId    String
  category      Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  answers       Answer[]
  gameQuestions GameQuestion[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([categoryId, difficulty])
  @@index([type])
}

model Answer {
  id         String   @id @default(cuid())
  text       String
  isCorrect  Boolean  @default(false)
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  order      Int      @default(0)
  playerAnswers PlayerAnswer[]
}

model Game {
  id            String       @id @default(cuid())
  code          String       @unique
  status        String       @default("LOBBY")
  hostName      String?
  difficulty    String       @default("MEDIUM")
  questionType  String       @default("MULTIPLE_CHOICE")
  tournamentModes String?
  tournamentTimeLimits String?
  timeLimitOverride Int?
  lastManStanding Boolean    @default(false)
  speedrunDuration Int?
  livesAllowed   Int?
  jeopardyMode   Boolean     @default(false)
  fiftyFiftyCount Int        @default(0)
  skipCount      Int         @default(0)
  localPartyMode Boolean     @default(false)
  pointsOverrides String?
  tournamentCategoryIds String?
  categoryPickMode Boolean   @default(false)
  totalQuestions Int         @default(10)
  currentIndex  Int          @default(0)
  players       Player[]
  gameQuestions GameQuestion[]
  createdAt     DateTime     @default(now())
  startedAt     DateTime?
  finishedAt    DateTime?

  @@index([code])
}

model GameQuestion {
  id         String   @id @default(cuid())
  gameId     String
  game       Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  questionId String
  question   Question @relation(fields: [questionId], references: [id])
  order      Int
  askedAt    DateTime?
  playerAnswers PlayerAnswer[]

  @@unique([gameId, order])
}

model Player {
  id         String   @id @default(cuid())
  nickname   String
  score      Int      @default(0)
  emoji      String?
  avatarUrl  String?
  eliminated Boolean  @default(false)
  wrongCount Int      @default(0)
  fiftyFiftyUsed Int   @default(0)
  skipUsed   Int      @default(0)
  streak     Int      @default(0)
  bestStreak Int      @default(0)
  pendingWager Int    @default(0)
  gameId     String
  game       Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  socketId   String?
  answers    PlayerAnswer[]
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  joinedAt   DateTime @default(now())

  @@index([gameId])
  @@index([userId])
}

model PlayerAnswer {
  id             String       @id @default(cuid())
  playerId       String
  player         Player       @relation(fields: [playerId], references: [id], onDelete: Cascade)
  gameQuestionId String
  gameQuestion   GameQuestion @relation(fields: [gameQuestionId], references: [id], onDelete: Cascade)
  answerId       String?
  answer         Answer?      @relation(fields: [answerId], references: [id])
  answerText     String?
  timeTaken      Int
  pointsEarned   Int          @default(0)
  isCorrect      Boolean      @default(false)
  judged         Boolean      @default(false)
  answeredAt     DateTime     @default(now())

  @@unique([playerId, gameQuestionId])
}

model Leaderboard {
  id             String   @id @default(cuid())
  nickname       String
  score          Int
  difficulty     String
  totalQuestions Int
  correctAnswers Int
  bestStreak     Int      @default(0)
  wrongCount     Int      @default(0)
  fiftyFiftyUsed Int      @default(0)
  skipUsed       Int      @default(0)
  eliminated     Boolean  @default(false)
  questionType   String?
  gameMode       String?
  userId         String?
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())

  @@index([score])
  @@index([difficulty])
  @@index([gameMode])
  @@index([userId])
}
