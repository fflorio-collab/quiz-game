{
  "name": "quiz-game",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "build": "prisma generate && next build",
    "build:prod": "prisma generate --schema=prisma/schema.production.prisma && next build",
    "prisma:sync-prod": "node scripts/sync-prod-schema.mjs",
    "db:refresh": "node scripts/sync-prod-schema.mjs && prisma generate && prisma db push --skip-generate",
    "hooks:install": "git config core.hooksPath .githooks && echo '✓ Git hooks attivi (.githooks)'",
    "start": "next start",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed-50": "tsx prisma/seed-50.ts",
    "db:seed-types": "tsx prisma/seed-types.ts",
    "db:seed-ghigliottina": "tsx prisma/seed-ghigliottina.ts",
    "db:seed-reaction": "tsx prisma/seed-reaction.ts",
    "db:seed-only-connect": "tsx prisma/seed-only-connect.ts",
    "db:seed-clue-reveal": "tsx prisma/seed-clue-reveal.ts",
    "db:seed-all": "npm run db:seed && npm run db:seed-50 && npm run db:seed-types && npm run db:seed-ghigliottina && npm run db:seed-reaction && npm run db:seed-only-connect && npm run db:seed-clue-reveal",
    "db:seed-subcategories": "tsx prisma/seed-subcategories.ts",
    "db:seed-subcategories-questions": "tsx prisma/seed-subcategories-questions.ts",
    "db:seed-extra-10": "tsx prisma/seed-extra-10.ts",
    "db:seed-badges": "tsx prisma/seed-badges.ts",
    "db:seed-autoimprenditorialita": "tsx prisma/seed-autoimprenditorialita.ts",
    "db:studio": "prisma studio",
    "lint": "next lint"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.5",
    "howler": "^2.2.4",
    "nanoid": "^5.0.9",
    "next": "^14.2.35",
    "next-auth": "^5.0.0-beta.31",
    "pusher": "^5.3.3",
    "pusher-js": "^8.5.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "stripe": "^22.0.2",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/howler": "^2.2.12",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.14.0",
    "eslint-config-next": "^14.2.35",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
